---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import BlogCard from '../components/BlogCard.astro';
import Footer from '../components/Footer.astro';
import ScrollReveal from '../components/ScrollReveal.tsx';
import { getCollection } from 'astro:content';

// All published posts, newest first
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const posts = allPosts.slice(0, 6).map((p) => ({
  module: p.data.module,
  readTime: p.data.readTime,
  title: p.data.title,
  description: p.data.description,
  href: `/blog/${p.id}`,
}));

const learningPaths = [
  {
    n: '01',
    heading: 'Building the foundation',
    desc: 'New to statistics or need a refresher? Start with probability, distributions, and the Central Limit Theorem. These concepts power everything else on this site.',
    href: '/blog/probability-theory-foundations',
    linkText: 'Start with the basics',
  },
  {
    n: '02',
    heading: 'Testing and inference',
    desc: 'Comfortable with the fundamentals? Learn how to design experiments, run hypothesis tests, and avoid the most common pitfalls in A/B testing and p-value interpretation.',
    href: '/blog/t-test-explained',
    linkText: 'Explore statistical tests',
  },
  {
    n: '03',
    heading: 'ML, explained statistically',
    desc: 'Ready to see how machine learning models actually work? We break down regression, classification, clustering, and dimensionality reduction through a statistical lens.',
    href: '/blog/decision-trees-explained',
    linkText: 'Dive into ML models',
  },
] as const;

const moduleFilters = [
  { key: 'all',  label: 'All'                },
  { key: 'A',    label: 'Foundations'         },
  { key: 'B',    label: 'Statistical Tests'   },
  { key: 'C',    label: 'ML Models'           },
  { key: 'D',    label: 'Business Analytics'  },
  { key: 'E',    label: 'AI & Deep Learning'  },
] as const;

const valueCards = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
    title: 'The math that matters',
    body: "We don't skip the formulas. Every concept is explained with the core math, step by step, with every variable defined.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
    title: 'Code you can actually run',
    body: 'Every post includes minimal, clean Python that you can copy, paste, and execute. The code follows the math directly.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    title: 'When to use it, and when not to',
    body: "We cover assumptions, limitations, and real business scenarios so you know when a tool is right and when it isn't.",
  },
] as const;

const structureSteps = [
  { n: '01', title: 'The underlying idea',    desc: 'Plain language, no prerequisites' },
  { n: '02', title: 'Historical root',         desc: 'Who built it, when, and why'       },
  { n: '03', title: 'Key assumptions',         desc: 'What must be true for it to work'  },
  { n: '04', title: 'The math',               desc: 'Core formulas, fully derived'       },
  { n: '05', title: 'The code',               desc: 'Clean Python you can run'           },
  { n: '06', title: 'Business application',   desc: 'When to use it, when not to'        },
] as const;
---

<Base
  title="Statbitall | The statistics behind the code."
  description="Understand the why behind every model, test, and algorithm. Statistics, machine learning, and causal inference explained with code and math."
  ogImage="/og-default.png"
>
  <Nav />

    <!-- ── 1. HERO ── -->
    <section class="hero">
      <!-- Background layer: gradient + dots + grid -->
      <div class="hero-bg" aria-hidden="true">
        <!-- Scattered data-node dots -->
        <span class="dot" style="top:8%;right:6%;width:4px;height:4px;opacity:0.45;background:#5DCAA5;"></span>
        <span class="dot" style="top:14%;right:18%;width:6px;height:6px;opacity:0.38;background:#7FA8D4;"></span>
        <span class="dot" style="top:6%;right:30%;width:2px;height:2px;opacity:0.42;background:#5DCAA5;"></span>
        <span class="dot" style="top:20%;right:9%;width:6px;height:6px;opacity:0.35;background:#7FA8D4;"></span>
        <span class="dot" style="top:22%;right:23%;width:3px;height:3px;opacity:0.48;background:#5DCAA5;"></span>
        <span class="dot" style="top:18%;right:38%;width:4px;height:4px;opacity:0.32;background:#7FA8D4;"></span>
        <span class="dot" style="top:10%;right:46%;width:2px;height:2px;opacity:0.40;background:#5DCAA5;"></span>
        <span class="dot" style="top:30%;right:12%;width:2px;height:2px;opacity:0.44;background:#5DCAA5;"></span>
        <span class="dot" style="top:35%;right:28%;width:6px;height:6px;opacity:0.36;background:#7FA8D4;"></span>
        <span class="dot" style="top:32%;right:44%;width:3px;height:3px;opacity:0.38;background:#5DCAA5;"></span>
        <span class="dot" style="top:28%;right:56%;width:4px;height:4px;opacity:0.30;background:#7FA8D4;"></span>
        <span class="dot" style="top:42%;right:7%;width:4px;height:4px;opacity:0.46;background:#7FA8D4;"></span>
        <span class="dot" style="top:45%;right:19%;width:2px;height:2px;opacity:0.42;background:#5DCAA5;"></span>
        <span class="dot" style="top:40%;right:34%;width:6px;height:6px;opacity:0.34;background:#5DCAA5;"></span>
        <span class="dot" style="top:48%;right:50%;width:2px;height:2px;opacity:0.35;background:#7FA8D4;"></span>
        <span class="dot" style="top:38%;right:62%;width:3px;height:3px;opacity:0.30;background:#5DCAA5;"></span>
        <span class="dot" style="top:55%;right:10%;width:6px;height:6px;opacity:0.40;background:#5DCAA5;"></span>
        <span class="dot" style="top:58%;right:25%;width:3px;height:3px;opacity:0.44;background:#7FA8D4;"></span>
        <span class="dot" style="top:52%;right:38%;width:4px;height:4px;opacity:0.36;background:#5DCAA5;"></span>
        <span class="dot" style="top:60%;right:54%;width:2px;height:2px;opacity:0.32;background:#7FA8D4;"></span>
        <span class="dot" style="top:65%;right:14%;width:2px;height:2px;opacity:0.48;background:#5DCAA5;"></span>
        <span class="dot" style="top:70%;right:30%;width:6px;height:6px;opacity:0.38;background:#7FA8D4;"></span>
        <span class="dot" style="top:68%;right:46%;width:3px;height:3px;opacity:0.33;background:#5DCAA5;"></span>
        <span class="dot" style="top:75%;right:8%;width:4px;height:4px;opacity:0.42;background:#7FA8D4;"></span>
        <span class="dot" style="top:78%;right:22%;width:2px;height:2px;opacity:0.46;background:#5DCAA5;"></span>
        <span class="dot" style="top:80%;right:40%;width:4px;height:4px;opacity:0.35;background:#7FA8D4;"></span>
        <span class="dot" style="top:82%;right:58%;width:3px;height:3px;opacity:0.30;background:#5DCAA5;"></span>
        <span class="dot" style="top:88%;right:16%;width:6px;height:6px;opacity:0.36;background:#5DCAA5;"></span>
        <span class="dot" style="top:90%;right:34%;width:2px;height:2px;opacity:0.40;background:#7FA8D4;"></span>
        <span class="dot" style="top:92%;right:50%;width:4px;height:4px;opacity:0.32;background:#5DCAA5;"></span>
      </div>

      <div class="hero-inner">
        <h1 class="hero-heading">
          The statistics <em>behind</em> the code.
        </h1>
        <p class="hero-sub">
          Every model has a formula. Every formula has a reason. We break down the
          statistical foundations of analytics, machine learning, and AI. So you
          understand what's really happening under the hood.
        </p>
        <a href="#latest-posts" class="cta-btn">Start reading</a>
      </div>
    </section>

    <!-- ── 2. WHAT YOU'LL FIND HERE ── -->
    <section class="value-section">
      <div class="section-inner">
        <ScrollReveal client:visible>
          <p class="section-label">Why Statbitall</p>
          <h2 class="section-heading">What you'll find here</h2>
          <p class="section-sub">
            Every post follows the same rigorous structure, so you never have to
            wonder what got skipped.
          </p>
        </ScrollReveal>

        <div class="value-cards">
          {valueCards.map((card, i) => (
            <ScrollReveal client:visible delay={i * 0.1}>
              <div class="value-card">
                <div class="value-icon" set:html={card.icon} />
                <h3 class="value-title">{card.title}</h3>
                <p class="value-body">{card.body}</p>
              </div>
            </ScrollReveal>
          ))}
        </div>
      </div>
    </section>

    <!-- ── 3. OUR APPROACH ── -->
    <section class="approach-section">
      <div class="section-inner approach-inner">
        <ScrollReveal client:visible>
          <div class="approach-left">
            <h2 class="approach-heading">
              Every post.<br />Same structure.<br />No shortcuts.
            </h2>
            <p class="approach-body">
              Statbitall breaks down every concept the same way, so you always know
              what to expect, and nothing gets skipped.
            </p>
          </div>
        </ScrollReveal>

        <ScrollReveal client:visible delay={0.1}>
          <ol class="structure-list">
            {structureSteps.map((step) => (
              <li class="structure-item">
                <span class="step-num">{step.n}</span>
                <span class="step-text"><strong>{step.title}.</strong> <span class="step-desc">{step.desc}</span></span>
              </li>
            ))}
          </ol>
        </ScrollReveal>
      </div>
    </section>

    <!-- ── 4. WHERE SHOULD YOU START? ── -->
    <section class="paths-section">
      <div class="section-inner">
        <ScrollReveal client:visible>
          <p class="section-label">Learning Paths</p>
          <h2 class="section-heading">Where should you start?</h2>
          <p class="section-sub">Pick the path that matches where you are right now.</p>
        </ScrollReveal>

        <div class="paths-grid">
          {learningPaths.map((path, i) => (
            <ScrollReveal client:visible delay={i * 0.1}>
              <div class="path-card">
                <span class="path-num">{path.n}</span>
                <h3 class="path-heading">{path.heading}</h3>
                <p class="path-desc">{path.desc}</p>
                <a href={path.href} class="path-link">
                  {path.linkText}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              </div>
            </ScrollReveal>
          ))}
        </div>
      </div>
    </section>

    <!-- ── 5. LATEST POSTS ── -->
    <section id="latest-posts" class="posts-section">
      <div class="section-inner">
        <h2 class="section-heading">Latest posts</h2>

        <div class="module-filter" role="group" aria-label="Filter by module">
          {moduleFilters.map(({ key, label }) => (
            <button class={`filter-pill${key === 'all' ? ' filter-pill--active' : ''}`} data-module={key}>
              {label}
            </button>
          ))}
        </div>

        <div class="cards-grid" id="cards-grid">
          {posts.map((post) => (
            <div data-module={post.module}>
              <BlogCard
                module={post.module}
                readTime={post.readTime}
                title={post.title}
                description={post.description}
                href={post.href}
              />
            </div>
          ))}
        </div>

        <div class="view-all">
          <a href="/blog" class="view-all-btn">View all posts</a>
        </div>
      </div>
    </section>

    <!-- ── 5. NEWSLETTER ── -->
    <section id="newsletter" class="newsletter-section">
      <div class="newsletter-inner">
        <ScrollReveal client:visible>
          <h2 class="newsletter-heading">One deep dive, every week.</h2>
          <p class="newsletter-sub">
            No fluff, no filler. Just the statistics behind the code, delivered to
            your inbox.
          </p>
          <form class="newsletter-form" onsubmit="return false;">
            <input
              type="email"
              placeholder="you@example.com"
              class="newsletter-input"
              aria-label="Email address"
            />
            <button type="submit" class="newsletter-btn">Subscribe</button>
          </form>
        </ScrollReveal>
      </div>
    </section>

    <!-- ── 6. FOOTER ── -->
    <Footer />

</Base>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
  const cards = document.querySelectorAll<HTMLElement>('#cards-grid [data-module]');

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      pills.forEach((p) => p.classList.remove('filter-pill--active'));
      pill.classList.add('filter-pill--active');

      const selected = pill.dataset.module;
      cards.forEach((card) => {
        card.style.display =
          selected === 'all' || card.dataset.module === selected ? '' : 'none';
      });
    });
  });
</script>

<style>
  /* ─── Shared layout ──────────────────────────── */
  .section-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 4rem 1.25rem;
  }
  @media (min-width: 640px)  { .section-inner { padding: 4rem 1.5rem; } }
  @media (min-width: 1024px) { .section-inner { padding: 4.5rem 2rem; } }

  .section-label {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #1B9E77;
    margin: 0 0 0.75rem;
  }

  .section-heading {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 28px;
    font-weight: 400;
    line-height: 1.25;
    color: var(--color-text-primary);
    margin: 0 0 0.75rem;
  }
  @media (min-width: 640px) { .section-heading { font-size: 32px; } }

  .section-sub {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 560px;
    margin: 0 0 2.5rem;
  }

  /* ─── Hero ──────────────────────────────────── */
  .hero {
    background-color: #0B1D3A;
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  /* Radial glow + grid texture */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    /* Right-side blue radial glow */
    background:
      radial-gradient(ellipse 55% 70% at 88% 40%, rgba(59,130,246,0.12) 0%, transparent 70%);
  }

  /* Thin grid overlay */
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  /* Data-node dots */
  .dot {
    position: absolute;
    border-radius: 50%;
    display: block;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1080px;
    margin: 0 auto;
    padding: 5rem 1.25rem 5.5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
  }
  @media (min-width: 640px)  { .hero-inner { padding: 6rem 1.5rem 6.5rem; } }
  @media (min-width: 1024px) { .hero-inner { padding: 7rem 2rem 7rem; } }

  .hero-heading {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 28px;
    font-weight: 400;
    line-height: 1.2;
    color: #ffffff;
    margin: 0;
    max-width: 720px;
  }
  @media (min-width: 640px) { .hero-heading { font-size: 36px; } }
  @media (min-width: 1024px) { .hero-heading { font-size: 44px; max-width: 720px; } }

  .hero-heading em {
    font-style: italic;
    color: #1B9E77;
  }

  .hero-sub {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.75;
    color: #7FA8D4;
    margin: 0;
    max-width: 480px;
  }
  @media (min-width: 640px) { .hero-sub { font-size: 17px; max-width: 520px; } }

  .cta-btn {
    display: inline-block;
    padding: 11px 26px;
    background-color: #1B9E77;
    color: #ffffff;
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 500;
    border-radius: 99px;
    text-decoration: none;
    transition: background-color 0.15s ease;
    margin-top: 0.25rem;
  }
  .cta-btn:hover { background-color: #0F6E56; }

  /* ─── Value section ─────────────────────────── */
  .value-section {
    background-color: var(--color-bg-page);
    width: 100%;
  }

  .value-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 768px) {
    .value-cards { grid-template-columns: repeat(3, 1fr); }
  }

  .value-card {
    height: 100%;
    background-color: var(--color-bg-surface);
    border: 0.5px solid var(--color-border-default);
    border-radius: 12px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-top-color 0.2s ease;
    border-top: 2px solid transparent;
  }
  .value-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.07);
    border-top-color: #1B9E77;
  }

  .value-icon {
    color: #1B9E77;
    display: flex;
  }

  .value-title {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 18px;
    font-weight: 400;
    line-height: 1.3;
    color: var(--color-text-primary);
    margin: 0;
  }

  .value-body {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* ScrollReveal wrappers in value grid need full height */
  .value-cards > :global(*) { height: 100%; }

  /* ─── Approach section ──────────────────────── */
  .approach-section {
    background-color: var(--color-bg-surface);
    border-top: 0.5px solid var(--color-border-default);
    border-bottom: 0.5px solid var(--color-border-default);
    width: 100%;
  }

  .approach-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 768px) {
    .approach-inner { grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
  }

  .approach-left { display: flex; flex-direction: column; gap: 1rem; }

  .approach-heading {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 26px;
    font-weight: 400;
    line-height: 1.25;
    color: var(--color-text-primary);
    margin: 0;
  }
  @media (min-width: 640px) { .approach-heading { font-size: 30px; } }

  .approach-body {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .structure-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .structure-item {
    display: flex;
    align-items: baseline;
    gap: 14px;
    padding: 0.85rem 0;
    border-bottom: 0.5px solid var(--color-border-subtle);
  }
  .structure-item:first-child { border-top: 0.5px solid var(--color-border-subtle); }

  .step-num {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 11px;
    font-weight: 400;
    color: #1B9E77;
    background-color: #E1F5EE;
    padding: 2px 7px;
    border-radius: 99px;
    flex-shrink: 0;
  }

  .step-text {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-text-primary);
  }

  .step-text strong { font-weight: 500; }

  .step-desc {
    color: var(--color-text-secondary);
  }

  /* ─── Learning paths ───────────────────────── */
  .paths-section {
    background-color: var(--color-bg-surface);
    border-top: 0.5px solid var(--color-border-default);
    border-bottom: 0.5px solid var(--color-border-default);
    width: 100%;
  }

  .paths-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 768px) {
    .paths-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .paths-grid > :global(*) { height: 100%; }

  .path-card {
    height: 100%;
    background-color: var(--color-bg-surface);
    border: 0.5px solid var(--color-border-default);
    border-radius: 20px;
    padding: 40px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .path-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.07);
  }

  .path-num {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 11px;
    font-weight: 400;
    color: #1B9E77;
    background-color: #E1F5EE;
    padding: 3px 10px;
    border-radius: 99px;
    display: inline-block;
    align-self: flex-start;
  }

  .path-heading {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 22px;
    font-weight: 400;
    line-height: 1.3;
    color: var(--color-text-primary);
    margin: 0;
  }

  .path-desc {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0;
    flex: 1;
  }

  .path-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #1B9E77;
