---
// Footer.astro
---

<footer style="background-color: #0B1D3A;">
  <div class="inner">
    <span class="logo">Statbitall</span>
    <span class="tagline">The statistics behind the code.</span>
    <span class="copy">&copy; 2025 Statbitall</span>
  </div>
</footer>

<style>
  footer {
    width: 100%;
    /* negative margin to break out of Base layout's max-width container */
  }

  .inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 3rem 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    text-align: center;
  }

  .logo {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 18px;
    font-weight: 400;
    color: #ffffff;
  }

  .tagline {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 12px;
    color: #7FA8D4;
  }

  .copy {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 12px;
    color: #7FA8D4;
    margin-top: 4px;
    opacity: 0.7;
  }
</style>
