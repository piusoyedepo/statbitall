---
// Footer.astro
---

<footer style="background-color: #0B1D3A;">
  <div class="inner">
    <span class="logo">Statbitall</span>
    <span class="tagline">The statistics behind the code.</span>

    <!-- Social + RSS links -->
    <div class="social-row">
      <a href="https://www.linkedin.com/company/112940458" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
          <rect x="2" y="9" width="4" height="12"/>
          <circle cx="4" cy="4" r="2"/>
        </svg>
      </a>
      <a href="https://x.com/statbitall" target="_blank" rel="noopener noreferrer" aria-label="Twitter / X" class="social-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
      <a href="https://github.com/piusoyedepo/statbitall" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="social-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
        </svg>
      </a>
      <a href="/rss.xml" aria-label="RSS feed" class="social-link">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <circle cx="5" cy="19" r="2"/>
          <path d="M4 4a16 16 0 0 1 16 16h-3A13 13 0 0 0 4 7V4z"/>
          <path d="M4 11a9 9 0 0 1 9 9H10a6 6 0 0 0-6-6v-3z"/>
        </svg>
      </a>
    </div>

    <span class="copy">&copy; 2026 Statbitall</span>
  </div>
</footer>

<style>
  footer { width: 100%; }

  .inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 3rem 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
  }

  .logo {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 18px;
    font-weight: 400;
    color: #ffffff;
  }

  .tagline {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 12px;
    color: #7FA8D4;
  }

  .social-row {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-top: 8px;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  .social-link:hover {
    color: #1B9E77;
    background-color: rgba(255, 255, 255, 0.08);
  }

  .copy {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 12px;
    color: #7FA8D4;
    opacity: 0.6;
    margin-top: 4px;
  }
</style>
