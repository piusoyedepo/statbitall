---
// Nav.astro — sticky site navigation
---

<nav
  style="background-color: #0B1D3A;"
  class="sticky top-0 z-50 w-full"
>
  <div class="mx-auto flex h-[60px] w-full max-w-[1080px] items-center justify-between px-5 md:px-8">
    <!-- Left: wordmark + tagline -->
    <div class="flex flex-col justify-center gap-0.5">
      <a
        href="/"
        class="text-[18px] leading-none text-white no-underline"
        style="font-family: 'Source Serif 4', Georgia, serif;"
      >
        Statbitall
      </a>
      <span
        class="text-[12px] leading-none"
        style="color: #7FA8D4; font-family: 'IBM Plex Sans', system-ui, sans-serif;"
      >
        The statistics behind the code.
      </span>
    </div>

    <!-- Right: links + dark mode toggle -->
    <div
      class="flex items-center gap-6"
      style="font-family: 'IBM Plex Sans', system-ui, sans-serif;"
    >
      <a
        href="/modules"
        class="text-[14px] text-white/80 no-underline transition-opacity duration-150 hover:text-white hover:opacity-100"
      >
        Modules
      </a>
      <a
        href="/about"
        class="text-[14px] text-white/80 no-underline transition-opacity duration-150 hover:text-white hover:opacity-100"
      >
        About
      </a>

      <!-- Dark mode toggle -->
      <button
        id="dark-toggle"
        onclick="window.toggleDark()"
        aria-label="Toggle dark mode"
        class="flex h-7 w-7 cursor-pointer items-center justify-center rounded border border-white/20 bg-transparent text-white/70 transition-colors duration-150 hover:border-white/40 hover:text-white"
      >
        <span class="dark-icon-sun hidden dark:inline" aria-hidden="true">
          <!-- Sun icon -->
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/>
            <line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </span>
        <span class="dark-icon-moon dark:hidden" aria-hidden="true">
          <!-- Moon icon -->
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </span>
      </button>
    </div>
  </div>
</nav>
