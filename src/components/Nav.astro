---
// Nav.astro — sticky site navigation with mobile hamburger
---

<nav style="background-color: #0B1D3A;" class="sticky top-0 z-50 w-full">
  <div class="nav-inner">
    <!-- Left: wordmark + tagline -->
    <div class="nav-brand">
      <a href="/" class="nav-logo">Statbitall</a>
      <span class="nav-tagline">The statistics behind the code.</span>
    </div>

    <!-- Right: desktop links + dark toggle -->
    <div class="nav-right">
      <a href="/#latest-posts" class="nav-link">Modules</a>
      <a href="/about" class="nav-link">About</a>
      <button
        id="dark-toggle"
        onclick="window.toggleDark()"
        aria-label="Toggle dark mode"
        class="nav-icon-btn"
      >
        <span class="icon-sun" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </span>
        <span class="icon-moon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </span>
      </button>
    </div>

    <!-- Mobile: dark toggle + hamburger -->
    <div class="nav-mobile-controls">
      <button
        onclick="window.toggleDark()"
        aria-label="Toggle dark mode"
        class="nav-icon-btn"
      >
        <span class="icon-sun" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </span>
        <span class="icon-moon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </span>
      </button>
      <button
        id="hamburger"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="nav-icon-btn hamburger-btn"
      >
        <svg class="icon-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg class="icon-close" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile dropdown menu -->
  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <a href="/#latest-posts" class="mobile-link" onclick="closeMobileMenu()">Modules</a>
    <a href="/about" class="mobile-link" onclick="closeMobileMenu()">About</a>
  </div>
</nav>

<style>
  /* ── Layout ── */
  .nav-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 1.25rem;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  @media (min-width: 768px) {
    .nav-inner { padding: 0 2rem; }
  }

  /* ── Brand ── */
  .nav-brand {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .nav-logo {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 18px;
    font-weight: 400;
    color: #ffffff;
    text-decoration: none;
    line-height: 1;
  }

  .nav-tagline {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 12px;
    color: #7FA8D4;
    line-height: 1;
  }

  /* ── Desktop links ── */
  .nav-right {
    display: none;
    align-items: center;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .nav-right { display: flex; }
  }

  .nav-link {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 14px;
    color: rgba(255,255,255,0.8);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .nav-link:hover { color: #ffffff; }

  /* ── Icon button (dark toggle / hamburger) ── */
  .nav-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 4px;
    color: rgba(255,255,255,0.7);
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
    flex-shrink: 0;
  }

  .nav-icon-btn:hover {
    border-color: rgba(255,255,255,0.4);
    color: #ffffff;
  }

  /* Sun/moon swap based on .dark on <html> */
  .icon-sun { display: none; }
  .icon-moon { display: flex; }

  :global(.dark) .icon-sun { display: flex; }
  :global(.dark) .icon-moon { display: none; }

  /* ── Mobile controls (hamburger row) ── */
  .nav-mobile-controls {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  @media (min-width: 640px) {
    .nav-mobile-controls { display: none; }
  }

  /* Hamburger open/close icon swap */
  .icon-close { display: none; }

  .hamburger-btn[aria-expanded="true"] .icon-open { display: none; }
  .hamburger-btn[aria-expanded="true"] .icon-close { display: flex; }

  /* ── Mobile dropdown ── */
  .mobile-menu {
    display: none;
    flex-direction: column;
    background-color: #0B1D3A;
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 0.75rem 1.25rem 1rem;
    gap: 0;
  }

  .mobile-menu.is-open {
    display: flex;
  }

  .mobile-link {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 15px;
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    padding: 0.6rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    transition: color 0.15s ease;
  }

  .mobile-link:last-child { border-bottom: none; }
  .mobile-link:hover { color: #ffffff; }
</style>

<script>
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');

  function closeMobileMenu() {
    mobileMenu?.classList.remove('is-open');
    hamburger?.setAttribute('aria-expanded', 'false');
    hamburger?.setAttribute('aria-label', 'Open menu');
  }

  hamburger?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('is-open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
    hamburger.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!hamburger?.contains(e.target as Node) && !mobileMenu?.contains(e.target as Node)) {
      closeMobileMenu();
    }
  });

  // Expose for mobile link onclick
  (window as any).closeMobileMenu = closeMobileMenu;
</script>
