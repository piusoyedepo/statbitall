---
import { getCollection } from 'astro:content';
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const searchData = allPosts.map((p) => ({
  title: p.data.title,
  description: p.data.description,
  href: `/blog/${p.id}`,
}));
---

<nav style="background-color: #0B1D3A;" class="sticky top-0 z-50 w-full">
  <div class="nav-inner">
    <!-- Left: logo mark + wordmark + tagline -->
    <div class="nav-brand">
      <a href="/" class="nav-logo-wrap" aria-label="Statbitall home">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true" class="nav-logomark">
          <rect x="1"  y="16" width="5" height="11" rx="1.5" fill="#3B82F6" opacity="0.55"/>
          <rect x="8"  y="10" width="5" height="17" rx="1.5" fill="#2A5BA0" opacity="0.75"/>
          <rect x="15" y="5"  width="5" height="22" rx="1.5" fill="#1B9E77"/>
          <rect x="22" y="12" width="5" height="15" rx="1.5" fill="#5DCAA5" opacity="0.8"/>
        </svg>
        <div class="nav-wordmark">
          <span class="nav-logo">Statbitall</span>
          <span class="nav-tagline">The statistics behind the code.</span>
        </div>
      </a>
    </div>

    <!-- Right: desktop links + search + dark toggle -->
    <div class="nav-right">
      <a href="/#latest-posts" class="nav-link">Blog</a>
      <a href="/about" class="nav-link">About</a>
      <a href="/#newsletter" class="nav-cta">Newsletter</a>
      <button
        id="search-btn"
        aria-label="Search posts"
        class="nav-icon-btn"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>
      <button
        id="dark-toggle"
        onclick="window.toggleDark()"
        aria-label="Toggle dark mode"
        class="nav-icon-btn"
      >
        <span class="icon-sun" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </span>
        <span class="icon-moon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </span>
      </button>
    </div>

    <!-- Mobile: dark toggle + hamburger -->
    <div class="nav-mobile-controls">
      <button
        onclick="window.toggleDark()"
        aria-label="Toggle dark mode"
        class="nav-icon-btn"
      >
        <span class="icon-sun" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </span>
        <span class="icon-moon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </span>
      </button>
      <button
        id="hamburger"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="nav-icon-btn hamburger-btn"
      >
        <svg class="icon-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg class="icon-close" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile dropdown menu -->
  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <a href="/#latest-posts" class="mobile-link" onclick="closeMobileMenu()">Blog</a>
    <a href="/about" class="mobile-link" onclick="closeMobileMenu()">About</a>
    <a href="/#newsletter" class="mobile-link mobile-link--cta" onclick="closeMobileMenu()">Newsletter</a>
  </div>

  <!-- Search overlay -->
  <div id="search-overlay" class="search-overlay" hidden>
    <div class="search-bar-row">
      <svg class="search-icon-inline" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input
        id="search-input"
        type="text"
        class="search-field"
        placeholder="Search posts..."
        autocomplete="off"
        aria-label="Search posts"
      />
      <button id="search-close" class="search-close" aria-label="Close search">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div id="search-results" class="search-results-list"></div>
  </div>
</nav>

<style>
  /* ── Layout ── */
  .nav-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 1.25rem;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  @media (min-width: 768px) {
    .nav-inner { padding: 0 2rem; }
  }

  /* ── Brand ── */
  .nav-brand {
    display: flex;
    align-items: center;
  }

  .nav-logo-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .nav-logomark {
    flex-shrink: 0;
  }

  .nav-wordmark {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .nav-logo {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 18px;
    font-weight: 400;
    color: #ffffff;
    line-height: 1;
  }

  .nav-tagline {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 12px;
    color: #7FA8D4;
    line-height: 1;
  }

  /* ── Desktop links ── */
  .nav-right {
    display: none;
    align-items: center;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .nav-right { display: flex; }
  }

  .nav-link {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 14px;
    color: rgba(255,255,255,0.8);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .nav-link:hover { color: #ffffff; }

  .nav-cta {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #ffffff;
    background-color: #1B9E77;
    text-decoration: none;
    padding: 6px 16px;
    border-radius: 99px;
    transition: background-color 0.15s ease;
    white-space: nowrap;
  }
  .nav-cta:hover { background-color: #0F6E56; }

  /* ── Icon button (dark toggle / hamburger) ── */
  .nav-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 4px;
    color: rgba(255,255,255,0.7);
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
    flex-shrink: 0;
  }

  .nav-icon-btn:hover {
    border-color: rgba(255,255,255,0.4);
    color: #ffffff;
  }

  /* Sun/moon swap based on .dark on <html> */
  .icon-sun { display: none; }
  .icon-moon { display: flex; }

  :global(.dark) .icon-sun { display: flex; }
  :global(.dark) .icon-moon { display: none; }

  /* ── Mobile controls (hamburger row) ── */
  .nav-mobile-controls {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  @media (min-width: 640px) {
    .nav-mobile-controls { display: none; }
  }

  /* Hamburger open/close icon swap */
  .icon-close { display: none; }

  .hamburger-btn[aria-expanded="true"] .icon-open { display: none; }
  .hamburger-btn[aria-expanded="true"] .icon-close { display: flex; }

  /* ── Mobile dropdown ── */
  .mobile-menu {
    display: none;
    flex-direction: column;
    background-color: #0B1D3A;
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 0.75rem 1.25rem 1rem;
    gap: 0;
  }

  .mobile-menu.is-open {
    display: flex;
  }

  .mobile-link {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 15px;
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    padding: 0.6rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    transition: color 0.15s ease;
  }

  .mobile-link:last-child { border-bottom: none; }
  .mobile-link:hover { color: #ffffff; }

  .mobile-link--cta {
    color: #5DCAA5;
    font-weight: 600;
  }
  .mobile-link--cta:hover { color: #1B9E77; }

  /* ── Search overlay ── */
  .search-overlay {
    background-color: #0B1D3A;
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 12px 1.25rem;
  }

  @media (min-width: 768px) {
    .search-overlay { padding: 12px 2rem; }
  }

  .search-bar-row {
    display: flex;
    align-items: center;
    gap: 10px;
    max-width: 600px;
    margin: 0 auto;
  }

  .search-icon-inline {
    color: rgba(255,255,255,0.5);
    flex-shrink: 0;
  }

  .search-field {
    flex: 1;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 6px;
    color: #ffffff;
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 14px;
    padding: 7px 12px;
    outline: none;
    transition: border-color 0.15s ease;
  }

  .search-field::placeholder { color: rgba(255,255,255,0.4); }
  .search-field:focus { border-color: #1B9E77; }

  .search-close {
    background: transparent;
    border: none;
    color: rgba(255,255,255,0.5);
    cursor: pointer;
    display: flex;
    align-items: center;
    padding: 4px;
    transition: color 0.15s ease;
    flex-shrink: 0;
  }

  .search-close:hover { color: #ffffff; }

  .search-results-list {
    max-width: 600px;
    margin: 8px auto 0;
    background: #ffffff;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
    display: none;
  }

  .search-results-list.has-results { display: block; }

  :global(.search-result-item) {
    display: block;
    padding: 12px 16px;
    text-decoration: none;
    border-bottom: 1px solid #EDEBE7;
    transition: background-color 0.1s ease;
  }

  :global(.search-result-item:last-child) { border-bottom: none; }
  :global(.search-result-item:hover) { background-color: #F5F3EF; }

  :global(.search-result-title) {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #1A1A1A;
    display: block;
    margin-bottom: 2px;
  }

  :global(.search-result-desc) {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 12px;
    color: #6B6B6B;
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.search-no-results) {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 14px;
    color: #6B6B6B;
    padding: 12px 16px;
    text-align: center;
  }
</style>

<script define:vars={{ searchData }}>
  // ── Search ──
  const searchBtn = document.getElementById('search-btn');
  const searchOverlay = document.getElementById('search-overlay');
  const searchInput = document.getElementById('search-input');
  const searchClose = document.getElementById('search-close');
  const searchResultsList = document.getElementById('search-results');

  function openSearch() {
    searchOverlay?.removeAttribute('hidden');
    searchInput?.focus();
  }

  function closeSearch() {
    searchOverlay?.setAttribute('hidden', '');
    if (searchResultsList) {
      searchResultsList.innerHTML = '';
      searchResultsList.classList.remove('has-results');
    }
    if (searchInput instanceof HTMLInputElement) searchInput.value = '';
  }

  searchBtn?.addEventListener('click', openSearch);
  searchClose?.addEventListener('click', closeSearch);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSearch();
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
    }
  });

  searchInput?.addEventListener('input', (e) => {
    const query = (e.target instanceof HTMLInputElement ? e.target.value : '').trim().toLowerCase();
    if (!searchResultsList) return;

    if (!query) {
      searchResultsList.innerHTML = '';
      searchResultsList.classList.remove('has-results');
      return;
    }

    const matches = searchData.filter((post) =>
      post.title.toLowerCase().includes(query) ||
      post.description.toLowerCase().includes(query)
    ).slice(0, 6);

    if (matches.length === 0) {
      searchResultsList.innerHTML = '<span class="search-no-results">No posts found</span>';
    } else {
      searchResultsList.innerHTML = matches.map((post) =>
        `<a href="${post.href}" class="search-result-item">
          <span class="search-result-title">${post.title}</span>
          <span class="search-result-desc">${post.description}</span>
        </a>`
      ).join('');
    }
    searchResultsList.classList.add('has-results');
  });
</script>

<script>
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');

  function closeMobileMenu() {
    mobileMenu?.classList.remove('is-open');
    hamburger?.setAttribute('aria-expanded', 'false');
    hamburger?.setAttribute('aria-label', 'Open menu');
  }

  hamburger?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('is-open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
    hamburger.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!hamburger?.contains(e.target as Node) && !mobileMenu?.contains(e.target as Node)) {
      closeMobileMenu();
    }
  });

  // Expose for mobile link onclick
  (window as any).closeMobileMenu = closeMobileMenu;
</script>
