---
interface Props {
  module: 'A' | 'B' | 'C' | 'D' | 'E';
}

const { module } = Astro.props;

const styles: Record<string, { bg: string; color: string }> = {
  A: { bg: '#D6E4F0', color: '#0B1D3A' },
  B: { bg: '#E1F5EE', color: '#0F6E56' },
  C: { bg: '#FAEEDA', color: '#854F0B' },
  D: { bg: '#EEEDFE', color: '#3C3489' },
  E: { bg: '#FAECE7', color: '#993C1D' },
};

const s = styles[module];
---

<span
  style={`background-color: ${s.bg}; color: ${s.color}; font-size: 11px; font-weight: 500; padding: 3px 10px; border-radius: 99px; font-family: 'IBM Plex Sans', system-ui, sans-serif; white-space: nowrap;`}
>
  Module {module}
</span>
