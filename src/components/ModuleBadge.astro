---
interface Props {
  module: 'A' | 'B' | 'C' | 'D' | 'E';
}

const { module } = Astro.props;

const config: Record<string, { bg: string; color: string; label: string }> = {
  A: { bg: '#D6E4F0', color: '#0B1D3A',  label: 'Foundations'        },
  B: { bg: '#E1F5EE', color: '#0F6E56',  label: 'Statistical Tests'  },
  C: { bg: '#FAEEDA', color: '#854F0B',  label: 'ML Models'           },
  D: { bg: '#EEEDFE', color: '#3C3489',  label: 'Business Analytics'  },
  E: { bg: '#FAECE7', color: '#993C1D',  label: 'AI & Deep Learning'  },
};

const { bg, color, label } = config[module];
---

<span
  style={`background-color: ${bg}; color: ${color}; font-size: 11px; font-weight: 500; padding: 3px 10px; border-radius: 99px; font-family: 'IBM Plex Sans', system-ui, sans-serif; white-space: nowrap;`}
>
  {label}
</span>
