---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import ModuleBadge from '../components/ModuleBadge.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  module: 'A' | 'B' | 'C' | 'D' | 'E';
  date: Date;
  readTime: string;
}

const { title, description, module, date, readTime } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={`${title} | Statbitall`} description={description} ogImage="/og-default.png">
  <Nav />

  <!-- TOC sidebar (desktop only, populated by JS) -->
  <nav class="toc-sidebar" id="toc-sidebar" aria-label="Table of contents"></nav>

  <article class="post-wrapper">
    <div class="post-inner">
      <!-- Back link -->
      <a href="/" class="back-link">← All posts</a>

      <!-- Meta row -->
      <div class="post-meta">
        <ModuleBadge module={module} />
        <span class="meta-sep">·</span>
        <time class="meta-text" datetime={date.toISOString()}>{formattedDate}</time>
        <span class="meta-sep">·</span>
        <span class="meta-text">{readTime}</span>
      </div>

      <!-- Title -->
      <h1 class="post-title">{title}</h1>

      <!-- Byline -->
      <p class="post-byline">By Pius Oyedepo</p>

      <!-- Prose content from MDX -->
      <div class="prose">
        <slot />
      </div>

      <!-- Author card -->
      <div class="author-card">
        <div class="author-avatar">PO</div>
        <div class="author-info">
          <p class="author-name">Pius Oyedepo</p>
          <p class="author-bio">Statistician and data analyst. Writing about the math behind the models.</p>
          <a
            href="https://www.linkedin.com/in/pius-oyedepo-30371283/"
            target="_blank"
            rel="noopener noreferrer"
            class="author-linkedin"
            aria-label="LinkedIn"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </article>

  <Footer />
</Base>

<style>
  .post-wrapper {
    background-color: var(--color-bg-page);
    width: 100%;
    min-height: calc(100vh - 60px);
  }

  .post-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 1.25rem 4rem;
  }

  @media (min-width: 768px) {
    .post-inner {
      padding: 3rem 2rem 4rem;
    }
  }

  /* Back link */
  .back-link {
    display: inline-block;
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 13px;
    color: var(--color-text-secondary);
    text-decoration: none;
    margin-bottom: 1.75rem;
    transition: color 0.15s ease;
  }

  .back-link:hover {
    color: #1B9E77;
  }

  /* Meta row */
  .post-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 1.25rem;
  }

  .meta-sep {
    color: var(--color-text-muted);
    font-size: 12px;
  }

  .meta-text {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 13px;
    color: var(--color-text-secondary);
  }

  /* Post title */
  .post-title {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 26px;
    font-weight: 400;
    line-height: 1.3;
    color: var(--color-text-primary);
    margin: 0 0 2.5rem;
  }

  @media (min-width: 640px) {
    .post-title { font-size: 32px; }
  }

  /* ── Prose styles ── */
  .prose {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-text-primary);
  }

  /* Headings */
  .prose :global(h2) {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 24px;
    font-weight: 400;
    line-height: 1.3;
    color: var(--color-text-primary);
    margin: 3rem 0 1rem;
  }

  .prose :global(h3) {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 20px;
    font-weight: 400;
    line-height: 1.3;
    color: var(--color-text-primary);
    margin: 2rem 0 0.75rem;
  }

  /* Paragraphs */
  .prose :global(p) {
    margin: 0 0 1.5rem;
  }

  /* Links */
  .prose :global(a) {
    color: #1B9E77;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(a:hover) {
    color: #0F6E56;
  }

  /* Inline code */
  .prose :global(:not(pre) > code) {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 13px;
    color: #1B9E77;
    background-color: var(--color-border-subtle);
    padding: 2px 6px;
    border-radius: 4px;
  }

  /* Code blocks — override Shiki's inline background */
  .prose :global(pre) {
    background-color: #1A1A2E !important;
    border-radius: 8px;
    padding: 16px 20px;
    overflow-x: auto;
    margin: 0 0 1.5rem;
    /* Full-bleed on mobile so long lines don't cause page overflow */
    max-width: 100%;
    -webkit-overflow-scrolling: touch;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 14px;
    line-height: 1.6;
    color: #E0E0E0;
  }

  /* Callout boxes — blockquote as callout */
  .prose :global(blockquote) {
    border-left: 3px solid #1B9E77;
    background-color: var(--color-bg-page);
    padding: 16px 20px;
    margin: 0 0 1.5rem;
    border-radius: 0;
  }

  .prose :global(blockquote p) {
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* Lists */
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
  }

  /* KaTeX display equations — allow horizontal scroll on mobile */
  .prose :global(.katex-display) {
    margin: 1.5rem 0;
    overflow-x: auto;
    text-align: center;
    -webkit-overflow-scrolling: touch;
  }

  /* Inline math: match surrounding body text */
  .prose :global(:not(.katex-display) > .katex) {
    font-size: 1em;
    line-height: 1.5;
  }

  /* TOC sidebar */
  .toc-sidebar {
    display: none;
    position: fixed;
    top: 80px;
    left: max(1rem, calc(50% - 580px));
    width: 190px;
    max-height: calc(100vh - 100px);
    overflow-y: auto;
    padding-right: 0.5rem;
  }

  @media (min-width: 1280px) {
    .toc-sidebar { display: block; }
  }

  /* Byline */
  .post-byline {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 14px;
    color: var(--color-text-secondary);
    margin: -1.75rem 0 2.5rem;
  }

  /* Author card */
  .author-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    border: 1px solid var(--color-border-subtle);
    border-radius: 12px;
    padding: 20px;
    margin-top: 3rem;
  }

  .author-avatar {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: #1B9E77;
    color: #ffffff;
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .author-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .author-name {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0;
  }

  .author-bio {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 13px;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  .author-linkedin {
    display: inline-flex;
    align-items: center;
    color: var(--color-text-secondary);
    margin-top: 6px;
    transition: color 0.15s ease;
  }

  .author-linkedin:hover {
    color: #1B9E77;
  }

  /* Strong */
  .prose :global(strong) {
    font-weight: 500;
    color: var(--color-text-primary);
  }

  /* Heading anchor links */
  .prose :global(h2),
  .prose :global(h3) {
    position: relative;
  }

  .prose :global(.heading-anchor) {
    position: absolute;
    left: -1.4rem;
    top: 50%;
    transform: translateY(-50%);
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 0.8em;
    font-weight: 400;
    color: var(--color-text-secondary);
    text-decoration: none;
    opacity: 0;
    transition: opacity 0.15s ease;
    line-height: 1;
  }

  .prose :global(h2:hover .heading-anchor),
  .prose :global(h3:hover .heading-anchor) {
    opacity: 1;
  }

  /* h2 scroll reveal */
  .prose :global(h2) {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.4s ease-out, transform 0.4s ease-out;
  }

  .prose :global(h2.revealed) {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .prose :global(h2) {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const headings = document.querySelectorAll<HTMLElement>('.prose h2');
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── Scroll-reveal for h2 ──
  if (prefersReduced) {
    headings.forEach((h) => h.classList.add('revealed'));
  } else {
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { rootMargin: '-20px' }
    );
    headings.forEach((h) => revealObserver.observe(h));
  }

  // ── Anchor links on h2 and h3 ──
  document.querySelectorAll<HTMLElement>('.prose h2, .prose h3').forEach((heading) => {
    const id = heading.id;
    if (!id) return;
    const anchor = document.createElement('a');
    anchor.href = `#${id}`;
    anchor.className = 'heading-anchor';
    anchor.setAttribute('aria-label', 'Link to this section');
    anchor.textContent = '#';
    heading.insertBefore(anchor, heading.firstChild);
  });

  // ── Table of contents (desktop only) ──
  const tocSidebar = document.getElementById('toc-sidebar');
  if (tocSidebar && headings.length > 0) {
    const tocList = document.createElement('ul');
    tocList.className = 'toc-list';
    tocList.style.cssText = 'list-style:none;margin:0;padding:0;';

    headings.forEach((heading) => {
      const id = heading.id;
      if (!id) return;
      const text = heading.textContent?.replace('#', '').trim() ?? '';
      const li = document.createElement('li');
      li.style.cssText = 'margin:0;';
      const a = document.createElement('a');
      a.href = `#${id}`;
      a.textContent = text;
      a.className = 'toc-link';
      a.style.cssText = [
        'display:block',
        'font-family:"IBM Plex Sans",system-ui,sans-serif',
        'font-size:13px',
        'line-height:1.4',
        'color:#6B6B6B',
        'text-decoration:none',
        'padding:4px 0 4px 10px',
        'border-left:2px solid transparent',
        'transition:color 0.15s ease,border-color 0.15s ease',
        'margin-bottom:2px',
      ].join(';');
      a.addEventListener('mouseenter', () => {
        if (!a.classList.contains('toc-link--active')) a.style.color = '#1A1A1A';
      });
      a.addEventListener('mouseleave', () => {
        if (!a.classList.contains('toc-link--active')) a.style.color = '#6B6B6B';
      });
      li.appendChild(a);
      tocList.appendChild(li);
    });

    tocSidebar.appendChild(tocList);

    // Highlight active section on scroll
    const tocLinks = tocSidebar.querySelectorAll<HTMLElement>('.toc-link');
    const setActive = (id: string) => {
      tocLinks.forEach((link) => {
        const isActive = link.getAttribute('href') === `#${id}`;
        link.classList.toggle('toc-link--active', isActive);
        link.style.color = isActive ? '#1B9E77' : '#6B6B6B';
        link.style.borderLeftColor = isActive ? '#1B9E77' : 'transparent';
        link.style.fontWeight = isActive ? '500' : '400';
      });
    };

    const activeObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) setActive(entry.target.id);
        });
      },
      { rootMargin: '-10% 0px -80% 0px' }
    );
    headings.forEach((h) => activeObserver.observe(h));
  }
</script>
